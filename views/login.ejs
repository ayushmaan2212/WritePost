<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Login</title>
    <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
  </head>
  <body>
    <!-- MAIN WRAPPER (centered) -->
    <div class="w-full min-h-screen bg-zinc-900 text-white flex items-center justify-center">

      <!-- CARD -->
      <div class="p-10 border border-zinc-800 rounded-lg w-full max-w-md">
        <h3 class="text-3xl mb-6 text-center">Login Account</h3>

        <form action="/login" method="post" class="flex flex-col gap-4">
          <input
            class="px-3 py-2 outline-none rounded-md bg-transparent border-2 border-zinc-800 focus:border-blue-500"
            type="email"
            placeholder="Email"
            name="email"
          >

          <input
            class="px-3 py-2 outline-none rounded-md bg-transparent border-2 border-zinc-800 focus:border-blue-500"
            type="password"
            placeholder="Password"
            name="password"
          >

          <input
            class="px-5 py-2 rounded-md bg-blue-500 hover:bg-blue-600 cursor-pointer"
            type="submit"
            value="Login"
          >
        </form>
        <!-- REGISTER OPTION -->
        <p class="text-sm text-center mt-5 text-zinc-400">
          Don’t have an account?
          <a href="/" class="text-blue-500 hover:underline">Register</a>
        </p>
      </div>

    </div>
  </body>
</html>
