<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Post Web</title>
    <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
  </head>
  <body>
    <div class="w-full min-h-screen bg-zinc-900 text-white">

      <!-- NAVBAR -->
      <div class="w-full flex justify-between items-center px-10 py-6 border-b border-zinc-800">
        <h2 class="text-xl font-semibold">PostWeb</h2>
        <a class="bg-red-500 hover:bg-red-600 rounded-md px-4 py-2 text-sm" href="/logout">
          Logout
        </a>
      </div>

      <!-- MAIN CONTENT -->
      <div class="max-w-4xl mx-auto px-6 py-10">

        <!-- PROFILE HEADER -->
        <div class="mb-10">
          <h3 class="text-3xl mb-1">
            <span class="font-light text-zinc-400">Hello</span>, <%= user.name %> 👋
          </h3>
          <p class="text-zinc-400">Share what’s on your mind</p>
        </div>

        <!-- CREATE POST -->
        <div class="mb-14">
          <form method="post" action="/post">
            <textarea
              placeholder="What's on your mind?"
              class="w-full p-4 min-h-[120px] outline-none bg-transparent border-2 border-zinc-800 rounded-lg focus:border-blue-500 resize-none"
              name="content"
            ></textarea>
            <input
              class="mt-3 px-5 py-2 text-sm bg-blue-500 hover:bg-blue-600 rounded-md cursor-pointer"
              type="submit"
              value="Create Post"
            >
          </form>
        </div>

        <!-- POSTS -->
        <div>
          <h3 class="text-zinc-400 mb-5">Your posts</h3>

          <div class="space-y-5">
            <% user.posts.reverse().forEach(function(post){ %>
              <div class="p-5 bg-zinc-800 rounded-lg border border-zinc-700">

                <!-- POST HEADER -->
                <div class="flex justify-between items-center mb-2">
                  <h3 class="text-blue-400 font-medium">@<%= user.username %></h3>
                  <small class="text-zinc-400 text-xs">
                    <%= post.likes.length %> likes
                  </small>
                </div>

                <!-- POST CONTENT -->
                <p class="text-sm text-zinc-200 leading-relaxed">
                  <%= post.content %>
                </p>

                <!-- ACTIONS -->
                <div class="flex gap-6 mt-3 text-sm">
                  <a class="text-blue-500 hover:underline" href="/like/<%= post._id %>">
                    <%= post.likes.indexOf(user._id) !== -1 ? "❤️" : "🤍" %>
                  </a>
                  <a class="text-zinc-400 hover:text-zinc-200" href="/edit/<%= post._id %>">
                    Edit
                  </a>
                  <a
                    href="/delete/<%= post._id %>"
                    class="text-red-500 text-sm hover:underline"
                    onclick="return confirm('Delete this post?')"
                    >
                   Delete
                  </a>
                </div>

              </div>
            <% }) %>
          </div>
        </div>

      </div>
    </div>
  </body>
</html>
